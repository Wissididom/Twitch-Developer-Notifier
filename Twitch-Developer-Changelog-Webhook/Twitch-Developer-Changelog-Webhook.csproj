  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ReverseMarkdown" Version="5.3.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Twitch-Developer-Common\Twitch-Developer-Common.csproj" />
  </ItemGroup>

</Project>
